{
  "name": "water-warner",
  "version": "1.0.0",
  "description": "A minimal Electron application written with Typescript",
  "engines": {
    "node": "^24.17.0"
  },
  "scripts": {
    "dev": "electron-forge start",
    "lint": "eslint .",
    "start": "electron-forge start",
    "build:icons": "electron-icon-builder --flatten --input=./seedling.png --output=.",
    "package": "yarn build:icons && electron-forge package",
    "build": "yarn build:icons && SKIP_NOTARIZE=true electron-forge package",
    "make": "yarn build:icons && electron-forge make",
    "release": "GITHUB_TOKEN=$(gh auth token) yarn release-it"
  },
  "main": ".vite/build/main.js",
  "repository": "https://github.com/ryami333/water-warner",
  "keywords": [
    "Electron",
    "quick",
    "start",
    "tutorial",
    "demo",
    "typescript"
  ],
  "author": "mitch@mitch-ryan.com",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-pkg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@t3-oss/env-core": "^0.13.11",
    "@types/ms": "^2.1.0",
    "@types/node": "24.13.2",
    "dotenv": "^17.4.2",
    "electron": "^42.4.1",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "ms": "^2.1.3",
    "zod": "^4.4.3"
  },
  "config": {
    "forge": "./forge.config.mjs"
  },
  "packageManager": "yarn@4.17.0"
}
