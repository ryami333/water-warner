{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "lib": ["dom", "es2022"],
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*"]
}
